# Copy to .env on the VM and chmod 600. NEVER commit .env.

# ── Public domains ───────────────────────────────────────
# Replace `tondomaine.dev` with your actual domain once DNS is set up.
DAGSTER_DOMAIN=dagster.tondomaine.dev
METABASE_DOMAIN=metabase.tondomaine.dev

# ── Let's Encrypt registration email (used by Caddy) ─────
ACME_EMAIL=you@example.com

# ── Dagster UI basic auth ────────────────────────────────
# Generate the bcrypt hash with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'yourpassword'
DAGSTER_BASIC_AUTH_USER=viewer
DAGSTER_BASIC_AUTH_HASH=$2a$14$REPLACE_ME_WITH_BCRYPT_HASH

# ── Dagster metadata Postgres ────────────────────────────
DAGSTER_DB_USER=dagster
DAGSTER_DB_PASSWORD=CHANGE_ME_LONG_RANDOM
DAGSTER_DB_NAME=dagster

# ── Metabase application Postgres ────────────────────────
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=CHANGE_ME_LONG_RANDOM
METABASE_DB_NAME=metabase
