# Copy this file to .dlt/secrets.toml and fill in your local values.
# .dlt/secrets.toml is gitignored at the repo root; never commit real credentials.

# ─── Snowflake destination (USER_DLT, ROLE_INGESTION) ──────
[destination.snowflake.credentials]
host = "<YOUR_SNOWFLAKE_ACCOUNT>"     # e.g. "xy12345.eu-west-1.aws" (legacy) or "ORG-ACCOUNT" (new format)
database = "RAW"
warehouse = "INGESTION_WH"
role = "ROLE_INGESTION"
username = "USER_DLT"

# Paste the FULL PEM content of the USER_DLT private key (.p8 file generated
# during the Phase 1 bootstrap) in place of the placeholder below. Keep the
# header/footer marker lines of the PEM block intact when you paste, and use
# a TOML triple-quoted string ("""...""") so newlines are preserved exactly.
private_key = "PASTE_USER_DLT_PEM_HERE"

# If the key was generated with a passphrase, also set:
# private_key_passphrase = "<passphrase>"

# ─── GCP / BigQuery source ─────────────────────────────────
# The pipeline reads the GCP service account via the GOOGLE_APPLICATION_CREDENTIALS
# environment variable (set in your shell, not in this file). Example:
#   PowerShell:  $env:GOOGLE_APPLICATION_CREDENTIALS = "<path-to-your-gcp-service-account>.json"
#   Bash:        export GOOGLE_APPLICATION_CREDENTIALS="<path-to-your-gcp-service-account>.json"
# google-cloud-bigquery picks it up automatically and bills queries against the
# project the service account belongs to. The TheLook dataset itself is public
# (bigquery-public-data.thelook_ecommerce).
