# ─── Terraform ───────────────────────────────────────────
# Local state (remote state lives on Terraform Cloud)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan output & crash logs
*.tfplan
crash.log
crash.*.log

# Provider binaries & lockfile for init
.terraform/
.terraform.lock.hcl

# Per-environment tfvars (checked in only as .example)
*.tfvars
*.tfvars.json
!*.tfvars.example
*.auto.tfvars
*.auto.tfvars.json

# Terraform override files (local-only, never committed)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# User-level Terraform config
.terraformrc
terraform.rc

